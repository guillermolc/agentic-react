# Backend environment variables
PORT=3001

# Base directory for cloned repositories (defaults to ~/work)
# WORK_DIR=/custom/path

# ── LLM Provider credentials ──────────────────────────────
# At least one provider must be configured.

# GitHub Copilot (required for Copilot Spaces and default agent runs)
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Vertex AI (optional — enables Vertex models like gemini-2.5-pro)
# Base64-encoded service account JSON: base64 < service-account.json
# VERTEX_SERVICE_ACCOUNT_B64=
# VERTEX_LOCATION=us-central1

# ── Bitbucket Server (optional) ──────────────────────────
# BITBUCKET_SERVER_URL=https://bitbucket.example.com
# BITBUCKET_PAT=

# ── Atlassian (optional) ─────────────────────────────────
# JIRA_URL=https://jira.example.com
# JIRA_PAT=
# CONFLUENCE_URL=https://confluence.example.com
# CONFLUENCE_PAT=

# ── SSL (optional) ───────────────────────────────────────
# Set to true to allow self-signed SSL certs (on-prem Bitbucket/Jira/Confluence)
# ALLOW_SELF_SIGNED_SSL=false
